{
  "name": "electron-shell",
  "version": "0.1.0",
  "main": "out/backend/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on http://localhost:5173 && nodemon --watch out --ext js --delay 1 --exec 'electron .'\"",
    "clean": "rm -rf out dist",
    "build": "npm run clean && tsc -p tsconfig.electron.json && vite build",
    "package": "electron-builder",
    "dist": "npm run build && npm run package",
    "start": "electron .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint src/frontend src/backend vite.config.ts",
    "format": "prettier --write src/frontend src/backend vite.config.ts index.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{html,json,md}": "prettier --write"
  },
  "build": {
    "appId": "com.electronshell.app",
    "productName": "ElectronShell",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "dist/**"
    ],
    "afterPack": "./scripts/afterPack.cjs",
    "asarUnpack": [
      "node_modules/@anthropic-ai/claude-agent-sdk/**",
      "node_modules/@anthropic-ai/claude-agent-sdk-darwin-arm64/**"
    ],
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@radix-ui/themes": "^3.3.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^5.0.0",
    "vitest": "^3.2.4",
    "wait-on": "^7.2.0"
  }
}
